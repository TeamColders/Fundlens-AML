# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=fundlens123

# PostgreSQL (optional — falls back to fundlens_demo.db SQLite)
POSTGRES_URL=postgresql://postgres:fundlens123@localhost:5432/fundlens

# Google Gemini — STR generation & NL-to-Cypher (required for live AI reports)
GEMINI_API_KEY=your_gemini_api_key_here
# Use the same model that works in your test script (avoid flash-lite — often limit: 0 on free tier)
GEMINI_STR_MODEL=gemini-2.0-flash
# Set true only if you need a second API call for Hindi (uses 2x quota)
# GEMINI_STR_HINDI_SEPARATE=false

# Kafka / Redis (optional for full pipeline)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
REDIS_URL=redis://localhost:6379

# API
API_PORT=8000
PORT=8000
CORS_ORIGINS=http://localhost:5173

# Deployment (see docs/DEPLOYMENT.md)
# SERVE_FRONTEND=1
# FUNDLENS_AUTO_SEED=1
# FUNDLENS_DATA_DIR=/data
# VITE_API_URL=https://your-api.onrender.com/api
