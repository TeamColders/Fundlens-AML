# FundLens AML Platform - Environment Variables Template
# Copy this to .env and fill in your values

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEPENDENCY_TIMEOUT_SECONDS=120
DEPENDENCY_RETRY_INTERVAL_SECONDS=2

# Frontend API routing
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://backend:8000
VITE_WS_PROXY_TARGET=ws://backend:8000

# Neo4j Graph Database
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# PostgreSQL (Cases & Alerts)
POSTGRES_DSN=postgresql://postgres:postgres@postgres:5432/fundlens

# Redis (Real-time Pub/Sub)
REDIS_URL=redis://redis:6379/0

# Kafka (Event Streaming)
KAFKA_BOOTSTRAP=kafka:9092

# GNN Model Service (Optional)
GNN_SCORE_URL=http://gnn:8001/score

# Real-time Alerts Channel
ALERTS_CHANNEL=alerts

# Production Database URLs (for Vercel deployment)
# NEO4J_URI=bolt://your-instance.databases.neo4j.io
# NEO4J_PASSWORD=your-production-password
# POSTGRES_DSN=postgresql://user:pass@host.region.provider.com:5432/fundlens
# REDIS_URL=redis://default:pass@host.upstash.io:port
